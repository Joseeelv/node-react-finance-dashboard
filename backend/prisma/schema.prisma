datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           Int           @id @default(autoincrement())
  name         String
  email        String        @unique
  password     String
  categories   Category[]
  transactions Transaction[]
}

model Transaction {
  uuid        String              @id @default(uuid())
  amount      Float
  date        DateTime            @default(now())
  description String?
  //Relations
  type        TransactionCategory @relation(fields: [typeId], references: [id])
  typeId      Int
  userId      Int
  category    Category?           @relation(fields: [categoryId], references: [id])
  categoryId  Int?
  user        User                @relation(fields: [userId], references: [id])
}

model TransactionCategory {
  id           Int           @id @default(autoincrement())
  name         String
  icon         String?
  transactions Transaction[]
}

model Category {
  id           Int           @id @default(autoincrement())
  name         String
  color        String
  icon         String?
  // Relations
  user         User?         @relation(fields: [userId], references: [id])
  userId       Int?
  transactions Transaction[]
}
